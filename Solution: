#include <bits/stdc++.h>
using namespace std;

int Func_longest_Valid_Parentheses(string s) {
    stack<int> st;
    st.push(-1); 
    int maxLen = 0;

    for (int i = 0; i < s.length(); i++) {
        if (s[i] == '(') {
            st.push(i);
        } else {
            st.pop();
            if (st.empty()) {
                st.push(i); 
            } else {
                maxLen = max(maxLen, i - st.top());
            }
        }
    }
    return maxLen;
}

int main() {
    string s;
    cin >> s;
    cout << Func_longest_Valid_Parentheses(s) << endl;   
}

